{
    "containerDefinitions": [
        {
            "name": "lks-container-leantime-app",
            "image": "leantime/leantime:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp",
                    "name": "lks-container-leantime-app-8080-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "LEAN_APP_URL",
                    "value": "http://lks-oss-lb-905921912.us-east-1.elb.amazonaws.com"
                },
                {
                    "name": "LEAN_LOG_PATH",
                    "value": "/logs/error.log"
                },
                {
                    "name": "LEAN_DEBUG",
                    "value": "0"
                },
                {
                    "name": "LEAN_LANGUAGE",
                    "value": "us-east-1"
                },
                {
                    "name": "LEAN_DEFAULT_TIMEZONE",
                    "value": "Asia/Jakarta"
                },
                {
                    "name": "LEAN_APP_DIR",
                    "value": "/leantime"
                },
                {
                    "name": "LEAN_DISABLE_LOGIN_FORM",
                    "value": "false"
                }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "public-userfiles",
                    "containerPath": "/var/www/html/public/userfiles",
                    "readOnly": false
                },
                {
                    "sourceVolume": "userfiles",
                    "containerPath": "/var/www/html/userfiles",
                    "readOnly": false
                },
                {
                    "sourceVolume": "plugins",
                    "containerPath": "/var/www/html/app/Plugins",
                    "readOnly": false
                }
            ],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "LEAN_DB_HOST",
                    "valueFrom": "/lks/db/host"
                },
                {
                    "name": "LEAN_DB_USER",
                    "valueFrom": "/lks/db/username"
                },
                {
                    "name": "LEAN_DB_PASSWORD",
                    "valueFrom": "/lks/db/password"
                },
                {
                    "name": "LEAN_DB_DATABASE",
                    "valueFrom": "/lks/db/name"
                },
                {
                    "name": "LEAN_DB_PORT",
                    "valueFrom": "/lks/db/port"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/lks-leantime-app",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ],
    "family": "lks-leantime-app",
    "taskRoleArn": "arn:aws:iam::214365501455:role/LabRole",
    "executionRoleArn": "arn:aws:iam::214365501455:role/LabRole",
    "networkMode": "awsvpc",
    "volumes": [
        {
            "name": "public-userfiles",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-04b7390bbf2149fd4",
                "rootDirectory": "/",
                "transitEncryption": "ENABLED",
                "authorizationConfig": {
                    "accessPointId": "fsap-088d97b9b9a5abb6c",
                    "iam": "ENABLED"
                }
            }
        },
        {
            "name": "userfiles",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-04b7390bbf2149fd4",
                "rootDirectory": "/",
                "transitEncryption": "ENABLED",
                "authorizationConfig": {
                    "accessPointId": "fsap-0772c6b504b8b3697",
                    "iam": "ENABLED"
                }
            }
        },
        {
            "name": "plugins",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-04b7390bbf2149fd4",
                "rootDirectory": "/",
                "transitEncryption": "ENABLED",
                "authorizationConfig": {
                    "accessPointId": "fsap-03e83d5f16e838195",
                    "iam": "ENABLED"
                }
            }
        }
    ],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048",
    "enableFaultInjection": false
}